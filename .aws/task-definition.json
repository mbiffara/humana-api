{
  "family": "humana-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "executionRoleArn": "arn:aws:iam::233053488031:role/humana-api-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::233053488031:role/humana-api-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "humana-api",
      "image": "233053488031.dkr.ecr.us-east-2.amazonaws.com/humana/humana-api:latest",
      "essential": true,
      "portMappings": [
        { "containerPort": 3000, "protocol": "tcp" }
      ],
      "environment": [
        { "name": "RAILS_ENV", "value": "production" },
        { "name": "RAILS_LOG_TO_STDOUT", "value": "1" },
        { "name": "RAILS_MAX_THREADS", "value": "5" },
        { "name": "API_VERSION", "value": "1.0.0" },
        { "name": "HUMANA_WEB_ORIGINS", "value": "https://staging.humana.global" }
      ],
      "secrets": [
        { "name": "RAILS_MASTER_KEY",  "valueFrom": "arn:aws:ssm:us-east-2:233053488031:parameter/humana-api/RAILS_MASTER_KEY" },
        { "name": "DATABASE_URL",      "valueFrom": "arn:aws:ssm:us-east-2:233053488031:parameter/humana-api/DATABASE_URL" },
        { "name": "HUMANA_JWT_SECRET", "valueFrom": "arn:aws:ssm:us-east-2:233053488031:parameter/humana-api/HUMANA_JWT_SECRET" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/humana-api",
          "awslogs-region": "us-east-2",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
